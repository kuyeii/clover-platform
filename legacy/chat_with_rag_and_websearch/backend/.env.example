# Server
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Workflow API (streaming SSE: data lines with event "text_chunk", data.text)
# Example: http://localhost/v1/workflows/run
UPSTREAM_URL=http://localhost/v1/workflows/run
# 仅填写密钥本身，形如 app-XXX；不要写 “Bearer ” 前缀，代码里会自动加 Authorization: Bearer …
UPSTREAM_BEARER_TOKEN=replace-with-your-bearer-token
UPSTREAM_TIMEOUT_SECONDS=120

# Request body field "user"
WORKFLOW_REMOTE_USER=admin

# Keys inside payload["inputs"]
WORKFLOW_QUESTION_INPUT_KEY=question
WORKFLOW_ALLOW_SEARCH_INPUT_KEY=allow_search
WORKFLOW_HISTORY_INPUT_KEY=history

# Dify OpenAPI 根地址（知识库 /datasets、工作流等共用同一 /v1 前缀；不要末尾斜杠）
# 与 UPSTREAM_URL 同机时一般为 http://host:port/v1
DIFY_API_BASE_URL=http://localhost/v1

# Dify 知识库 API（上传文档、管理分段等时使用；与工作流的 app-XXX 常为不同密钥）
# 仅填写密钥本身，形如 dataset-XXXXXXXX；HTTP 请求头中为 Authorization: Bearer dataset-XXXXXXXX（不要在这里写「Bearer 」前缀）
DIFY_DATASET_API_KEY=

# 知识库管理（列表/删除文档等）默认针对的知识库 UUID
DIFY_DEFAULT_DATASET_ID=

# 本地数据目录（相对 backend/ 或绝对路径）
DATA_DIR=../data
# 前端「最近」会话列表：SQLite 库文件 {DATA_DIR}/conversations.sqlite；当前打开哪条会话由各浏览器标签页自行决定
