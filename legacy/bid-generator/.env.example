# =========================
# 本地开发基础配置
# =========================

# Dify API 根地址
DIFY_API_URL=http://localhost/v1

# 可选：Dify 控制台与导入令牌
DIFY_CONSOLE_URL=http://localhost
DIFY_IMPORT_TOKEN=

# 当前纳管 workflow keys
DIFY_WORKFLOW_STRUCTURE_GENERATOR=app-xxxx
DIFY_WORKFLOW_CONTENT_WRITER=app-xxxx
DIFY_WORKFLOW_CONTENT_GROUP_WRITER=app-xxxx
DIFY_WORKFLOW_CONTENT_REWRITE=app-xxxx
DIFY_WORKFLOW_RESPONSE_CONTENT_WRITER=app-xxxx
DIFY_WORKFLOW_DIAGRAM_GENERATOR=app-xxxx
DIFY_WORKFLOW_DOC_ANALYSIS=app-xxxx

# 可选：知识库
DIFY_DATASET_API_KEY=
DIFY_BID_BASE_ID=

# 历史兼容链路；仅在你仍启用对应代码路径时填写
DIFY_WORKFLOW_REQUIREMENT_EXTRACTOR=
DIFY_WORKFLOW_BLUEPRINT_GENERATOR=
DIFY_WORKFLOW_GROUP_REVIEW_WRITER=
DIFY_WORKFLOW_ATTACHMENT_GENERATOR=
DIFY_WORKFLOW_SCORING_ASSISTANT=

# 可选：图像/VLM 与校验模型
VLM_API_URL=
PIPT_LLM_VERIFY_ENABLED=false
