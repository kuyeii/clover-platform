# =========================
# 核心部署配置
# =========================

# 前端对外端口
FRONTEND_PORT=8060

# 前端构建时写入的 API 地址。使用同域反向代理时保持 /api 即可。
VITE_API_URL=/api

# 仅允许你的前端域名访问后端。多个域名用逗号分隔。
PIPT_CORS_ORIGINS=https://your-domain.example

# SQLite 加密密钥（生产环境必须配置）
# 生成方式：
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
PIPT_DB_KEY=replace_with_fernet_key

# Dify 地址：服务器必须能访问。
DIFY_API_URL=http://your-home-dify-endpoint:3000/v1

# 部署说明：
# 1. 生产镜像默认要求离线 HanLP 模型资产存在于
#    pipt-flask/app/extension/celery_task/pipt_task/assets
# 2. 首次修复依赖或模型缺失后，务必执行
#    docker-compose -f docker-compose.yml build --no-cache backend
#    再重新启动，避免继续复用旧镜像层

# =========================
# Dify workflow keys
# 当前纳管 workflow 建议全部配置
# =========================

DIFY_WORKFLOW_STRUCTURE_GENERATOR=app-xxxx
DIFY_WORKFLOW_CONTENT_WRITER=app-xxxx
DIFY_WORKFLOW_CONTENT_GROUP_WRITER=app-xxxx
DIFY_WORKFLOW_CONTENT_REWRITE=app-xxxx
DIFY_WORKFLOW_RESPONSE_CONTENT_WRITER=app-xxxx
DIFY_WORKFLOW_DIAGRAM_GENERATOR=app-xxxx
DIFY_WORKFLOW_DOC_ANALYSIS=app-xxxx

# 历史兼容链路；仅在你仍启用对应代码路径时填写
DIFY_WORKFLOW_REQUIREMENT_EXTRACTOR=app-xxxx
DIFY_WORKFLOW_BLUEPRINT_GENERATOR=app-xxxx

# 可选：H2 章节评估
DIFY_WORKFLOW_GROUP_REVIEW_WRITER=app-xxxx

# 可选：动态附件生成
DIFY_WORKFLOW_ATTACHMENT_GENERATOR=app-xxxx

# 可选：评分表 AI 填写
DIFY_WORKFLOW_SCORING_ASSISTANT=app-xxxx

# =========================
# 可选增强配置
# 不用对应能力时可保持默认或留空
# =========================

# 图片/VLM 打标链路
VLM_API_URL=http://your-home-vlm-endpoint:8000/v1/chat/completions
VLM_MODEL=qwen-vl-chat
VLM_TIMEOUT=120
VLM_MAX_TOKENS=200

# PIPT 二次校验链路；默认关闭
PIPT_LLM_VERIFY_ENABLED=false
PIPT_LLM_VERIFY_API_URL=http://your-home-verify-endpoint:8000/v1/chat/completions
PIPT_LLM_VERIFY_MODEL=qwen-chat
PIPT_LLM_VERIFY_API_KEY=EMPTY
PIPT_LLM_MODE=verify_only
PIPT_LLM_MODE_EXTRACT=verify_only
