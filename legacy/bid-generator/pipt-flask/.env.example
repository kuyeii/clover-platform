# pipt-lite standalone development environment.
# Prefer the clover-platform root .env when running through scripts/dev.py.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# DATABASE_URL=postgresql+psycopg://postgres:change-me@127.0.0.1:5432/app_db

# PIPT_DB_KEY encrypts bid_generator.entity_registry.original_text_enc.
# In development it may be omitted; PIPT_ENV=production requires it.
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PIPT_ENV=development
PIPT_DB_KEY=

PIPT_CORS_ORIGINS=*
