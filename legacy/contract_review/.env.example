# Dify API 服务地址。Docker 内如果 Dify 运行在宿主机，可按系统改成：
# macOS/Windows: http://host.docker.internal/v1
# Linux: http://<宿主机局域网IP>:<端口>/v1
DIFY_BASE_URL=http://localhost/v1

# PostgreSQL 连接优先从 clover-platform 根目录 .env 读取。
# 单独调试本模块时，可在此处配置 DATABASE_URL 或完整 POSTGRES_*。
DATABASE_URL=postgresql+psycopg://postgres:<password>@127.0.0.1:5432/app_db
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=app_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=<password>

# 必填：当前审查流程使用的 Dify 工作流 API Key
DIFY_CLAUSE_WORKFLOW_API_KEY=app-clause
DIFY_ANCHORED_RISK_WORKFLOW_API_KEY=app-anchored-risk
DIFY_MISSING_MULTI_RISK_WORKFLOW_API_KEY=app-missing-multi-risk
DIFY_FAST_SCREEN_WORKFLOW_API_KEY=app-fast-screen
DIFY_REWRITE_WORKFLOW_API_KEY=app-rewrite
DIFY_AGGREGATE_REWRITE_WORKFLOW_API_KEY=app-aggregate-rewrite

# 审查配置
# supplier = 供应商/乙方视角；customer = 采购方/甲方视角
REVIEW_SIDE=supplier
CONTRACT_TYPE_HINT=service_agreement
ANALYSIS_SCOPE=full_detail

# Dify 调用与并发配置
REQUEST_TIMEOUT_SECONDS=900
DIFY_MAX_CONCURRENCY=6
CLAUSE_SPLIT_MAX_CONCURRENCY=3
AI_REWRITE_MAX_CONCURRENCY=5

# Fast Screen 配置
FAST_SCREEN_ENABLED=1
FAST_SCREEN_MAX_CANDIDATES=12

# 本地运行目录；Docker Compose 会覆盖为 /app/data/...
RUN_ROOT=data/runs

# 可选：将写入文件系统的 JSON / 文本运行产物同步索引到 PostgreSQL。
MIRROR_RUN_ARTIFACTS_TO_DB=0

# 可选：手动指定 LibreOffice/soffice 路径，用于 .doc 转 .docx 等文档处理
# macOS 示例：/Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_PATH=

# 可选：前端本地开发时覆盖 Vite 代理目标
VITE_API_TARGET=http://127.0.0.1:8000
