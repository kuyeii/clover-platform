# 后端服务
BACKEND_PORT=8788
BACKEND_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5174
HISTORY_MAX_ITEMS=200

# 通用 Dify Workflow 地址；也可以为每个工作流单独配置 *_URL
WORKFLOW_URL=http://localhost/v1/workflows/run
COMPANY_DETAIL_URL=http://localhost/v1/workflows/run
COMPARE_REPORT_URL=http://localhost/v1/workflows/run
SCORE_URL=http://localhost/v1/workflows/run
DIFY_WORKFLOW_TIMEOUT_SECONDS=600

# 输入校验 / 竞争对手发现工作流
WORKFLOW_API_KEY=replace_with_your_api_key
WORKFLOW_USER=admin

# 首页企业名称候选校验工作流
COMPANY_NAME_VALIDATION_URL=http://localhost/v1/workflows/run
COMPANY_NAME_VALIDATION_API_KEY=replace_with_company_name_validation_api_key
COMPANY_NAME_VALIDATION_USER=admin

# 企业详情工作流
COMPANY_DETAIL_API_KEY=replace_with_company_detail_api_key
COMPANY_DETAIL_USER=admin
COMPANY_DETAIL_TIMEOUT_SECONDS=900

# 对比报告：4 个子工作流 + 回退。
# 若 4 个子工作流 KEY 均未设置，则使用 COMPARE_REPORT_API_KEY 作为回退。
COMPARE_REPORT_API_KEY=replace_with_compare_report_api_key
COMPARE_REPORT_USER=admin
COMPARE_REPORT_PRODUCT_URL=http://localhost/v1/workflows/run
COMPARE_REPORT_PRODUCT_API_KEY=replace_with_product_workflow_key
COMPARE_REPORT_TECH_URL=http://localhost/v1/workflows/run
COMPARE_REPORT_TECH_API_KEY=replace_with_tech_workflow_key
COMPARE_REPORT_LATELY_URL=http://localhost/v1/workflows/run
COMPARE_REPORT_LATELY_API_KEY=replace_with_lately_workflow_key
COMPARE_REPORT_SUMMARY_URL=http://localhost/v1/workflows/run
COMPARE_REPORT_SUMMARY_API_KEY=replace_with_summary_workflow_key

# 评分工作流
# 后端优先读取 SCORE_API_KEY；如果你的旧 .env.local 只有 VITE_SCORE_API_KEY，也会自动回退兼容。
# Docker/生产部署建议改用 SCORE_API_KEY，避免把密钥放进 Vite 前端变量命名空间。
SCORE_URL=http://localhost/v1/workflows/run
SCORE_API_KEY=replace_with_score_api_key
# VITE_SCORE_API_KEY=replace_with_existing_score_api_key
SCORE_USER=admin

# 兼容说明：后端仍可读取旧版 VITE_* 变量；新项目建议逐步改用非 VITE_ 变量，避免前端打包暴露密钥。
