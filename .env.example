APP_ENV=prod

# Docker Compose PostgreSQL 18 defaults. The api container connects through the
# internal service name `postgres`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123456
POSTGRES_PUBLISHED_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres123456@postgres:5432/app_db
WEB_PUBLISHED_PORT=5200

# Portal PostgreSQL bootstrap account. Change before production.
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=admin123456
PORTAL_ADMIN_DISPLAY_NAME=系统管理员

# Bid generator encrypts original sensitive text with this key in production.
# Required when PIPT_ENV=prod. Generate one with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PIPT_DB_KEY=
PIPT_ENV=prod

# Legacy iframe URLs are configured locally when unified runtime loading is implemented.
# PORTAL_URL=
# CONTRACT_REVIEW_URL=
# BID_GENERATOR_URL=
# RAG_QA_URL=
# COMPETITOR_ANALYSIS_URL=
