APP_ENV=prod

# Docker Compose PostgreSQL 18 defaults. The api container connects through the
# internal service name `postgres`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123456
POSTGRES_PUBLISHED_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres123456@postgres:5432/app_db
WEB_PUBLISHED_PORT=5200

# Portal PostgreSQL bootstrap account. Change before production.
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=admin123456
PORTAL_ADMIN_DISPLAY_NAME=系统管理员

# Bid generator encrypts original sensitive text with this key in production.
# Required when PIPT_ENV=prod. Generate one with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PIPT_DB_KEY=
PIPT_ENV=prod

# Bid generator knowledge image tagging. Disabled by default; when disabled,
# knowledge sync still works with weak fallback captions.
REMOTE_VISION_ENABLED=false
REMOTE_VISION_API_URL=
REMOTE_VISION_API_KEY=
REMOTE_VISION_MODEL=
REMOTE_VISION_TIMEOUT=120
REMOTE_VISION_MAX_TOKENS=400

# 标书大纲 native pipeline：不再调用 Dify Workflow；use_knowledge=true 时仍使用 Dify Dataset 知识库。
BID_OUTLINE_LLM_BASE_URL=https://your-relay.example.com/v1
BID_OUTLINE_LLM_API_KEY=
BID_OUTLINE_LLM_MODEL=
BID_OUTLINE_LLM_TIMEOUT_SECONDS=300
BID_OUTLINE_LLM_MAX_RETRIES=2
BID_OUTLINE_LLM_TEMPERATURE=0.2
BID_OUTLINE_NATIVE_MAX_CONCURRENCY=2
DIFY_API_BASE_URL=http://dify-api/v1
DIFY_DATASET_API_KEY=
DIFY_DEFAULT_DATASET_ID=
BID_OUTLINE_DATASET_ID=

# Bid generator SVG diagram generation. Disabled by default.
ENABLE_DIAGRAM_GENERATION=false
DIFY_WORKFLOW_DIAGRAM_GENERATOR_MERMAID=
DIAGRAM_GENERATOR_MODE=svg
MAX_DIAGRAM_RUNNING_TASKS=1
DIAGRAM_ARTIFACT_DIR=/app/legacy/bid-generator/data/diagram_artifacts
# Optional Mermaid CLI render tuning. Install @mermaid-js/mermaid-cli and expose mmdc on PATH.
MERMAID_RENDER_SCALE=2
MERMAID_RENDER_WIDTH=1400
MERMAID_RENDER_HEIGHT=1050
VITE_MAX_DIAGRAMS=3

# Patent disclosure native module. Configure an OpenAI-compatible relay before generation.
PATENT_DISCLOSURE_ENABLED=true
PATENT_DISCLOSURE_DATA_DIR=/app/data/patent_disclosure
PATENT_DISCLOSURE_SKILL_DIR=/app/packages/patent_disclosure_skill/upstream
PATENT_DISCLOSURE_MAX_FILE_SIZE_MB=50
PATENT_DISCLOSURE_MAX_CASE_SIZE_MB=300
PATENT_DISCLOSURE_ALLOWED_EXTENSIONS=.md,.txt,.docx,.pptx,.pdf,.zip
PATENT_DISCLOSURE_LLM_BASE_URL=https://your-relay.example.com/v1
PATENT_DISCLOSURE_LLM_API_KEY=
PATENT_DISCLOSURE_LLM_MODEL=
PATENT_DISCLOSURE_LLM_TIMEOUT_SECONDS=180
PATENT_DISCLOSURE_LLM_MAX_RETRIES=2
PATENT_DISCLOSURE_LLM_TEMPERATURE=0.2
PATENT_DISCLOSURE_CNIPA_ENABLED=true
PATENT_DISCLOSURE_CNIPA_TIMEOUT_SECONDS=300
PATENT_DISCLOSURE_CNIPA_MAX_RESULTS=20
PATENT_DISCLOSURE_ENABLE_MERMAID_RENDER=true
PATENT_DISCLOSURE_TOOL_TIMEOUT_SECONDS=300

# Legacy iframe URLs are configured locally when unified runtime loading is implemented.
# PORTAL_URL=
# CONTRACT_REVIEW_URL=
# BID_GENERATOR_URL=
# RAG_QA_URL=
# COMPETITOR_ANALYSIS_URL=
