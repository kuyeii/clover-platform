APP_ENV=prod

# External PostgreSQL connection used by docker/docker-compose.external-postgres.yml.
# If the database is deployed with the PostgreSQL Compose snippet below, keep the
# port/db/user/password defaults and set EXTERNAL_POSTGRES_HOST to that server's
# reachable IP address or DNS name.
EXTERNAL_POSTGRES_HOST=YOUR_POSTGRES_SERVER_IP_OR_DNS
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_POSTGRES_DB=app_db
EXTERNAL_POSTGRES_USER=postgres
EXTERNAL_POSTGRES_PASSWORD=postgres123456

WEB_PUBLISHED_PORT=5200

# Portal PostgreSQL bootstrap account. Change before production.
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=admin123456
PORTAL_ADMIN_DISPLAY_NAME=系统管理员

# Bid generator encrypts original sensitive text with this key in production.
# Required when PIPT_ENV=prod. Generate one with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PIPT_DB_KEY=
PIPT_ENV=prod

# Bid generator knowledge image tagging. Disabled by default; when disabled,
# knowledge sync still works with weak fallback captions.
REMOTE_VISION_ENABLED=false
REMOTE_VISION_API_URL=
REMOTE_VISION_API_KEY=
REMOTE_VISION_MODEL=
REMOTE_VISION_TIMEOUT=120
REMOTE_VISION_MAX_TOKENS=400

# 标书大纲 native pipeline：不再调用 Dify Workflow；use_knowledge=true 时仍使用 Dify Dataset 知识库。
BID_OUTLINE_LLM_BASE_URL=https://your-relay.example.com/v1
BID_OUTLINE_LLM_API_KEY=
BID_OUTLINE_LLM_MODEL=
BID_OUTLINE_LLM_TIMEOUT_SECONDS=300
BID_OUTLINE_LLM_MAX_RETRIES=2
BID_OUTLINE_LLM_TEMPERATURE=0.2
BID_OUTLINE_NATIVE_MAX_CONCURRENCY=2
DIFY_API_BASE_URL=http://dify-api/v1
DIFY_DATASET_API_KEY=
DIFY_DEFAULT_DATASET_ID=
BID_OUTLINE_DATASET_ID=

# Bid generator SVG diagram generation. Disabled by default.
ENABLE_DIAGRAM_GENERATION=false
MAX_DIAGRAM_RUNNING_TASKS=1
DIAGRAM_ARTIFACT_DIR=/app/legacy/bid-generator/data/diagram_artifacts
VITE_MAX_DIAGRAMS=3

# Legacy iframe URLs are configured locally when unified runtime loading is implemented.
# PORTAL_URL=
# CONTRACT_REVIEW_URL=
# BID_GENERATOR_URL=
# RAG_QA_URL=
# COMPETITOR_ANALYSIS_URL=
