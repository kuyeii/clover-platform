FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_RETRIES=10 \
    PIP_DEFAULT_TIMEOUT=120 \
    PYTHONPATH=/app:/app/apps/api:/app/legacy/contract_review \
    PIPT_ROOT=/app/legacy/bid-generator/pipt-flask \
    PRO_ENGINE_ROOT=/app/legacy/bid-generator \
    PUPPETEER_SKIP_DOWNLOAD=true \
    SOFFICE_PATH=/usr/bin/libreoffice

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      curl \
      build-essential \
      fontconfig \
      fonts-noto-cjk \
      libgl1 \
      libglib2.0-0 \
      libcairo2-dev \
      libmagic1 \
      libreoffice \
      libreoffice-writer \
      libreoffice-l10n-zh-cn \
      nodejs \
      npm \
      pkg-config \
      poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-dev.txt ./requirements-dev.txt
COPY apps/api/requirements.txt ./apps/api/requirements.txt
COPY legacy/contract_review/requirements.txt ./legacy/contract_review/requirements.txt
COPY legacy/bid-generator/pipt-flask/requirements-lite.txt ./legacy/bid-generator/pipt-flask/requirements-lite.txt

RUN python -m pip install --upgrade pip
RUN python -m pip install -r requirements-dev.txt
RUN python -m pip install -r apps/api/requirements.txt
RUN python -m pip install -r legacy/contract_review/requirements.txt
RUN python -m pip install torch==2.1.2 --index-url https://download.pytorch.org/whl/cpu
RUN python -m pip install -r legacy/bid-generator/pipt-flask/requirements-lite.txt
RUN python -m pip install \
      "docx2pdf>=0.1.8" \
      "exrex>=0.12.0" \
      "markdown>=3.6" \
      "olefile>=0.47" \
      "pymupdf4llm>=0.0.5"
RUN python -m playwright install --with-deps chromium

COPY alembic ./alembic
COPY alembic.ini ./alembic.ini
COPY apps ./apps
COPY config ./config
COPY legacy/portal-launchpad ./legacy/portal-launchpad
COPY legacy/contract_review ./legacy/contract_review
COPY legacy/bid-generator ./legacy/bid-generator
COPY modules ./modules
COPY packages ./packages
COPY scripts ./scripts
COPY runtime/.gitkeep ./runtime/.gitkeep

RUN npm ci --prefix packages/patent_disclosure_skill/upstream/tools

RUN mkdir -p \
      /app/runtime \
      /app/data/patent_disclosure \
      /app/legacy/contract_review/data/uploads \
      /app/legacy/contract_review/data/runs \
      /app/legacy/bid-generator/data/pdf_cache \
      /app/legacy/bid-generator/data/docx_cache \
      /app/legacy/bid-generator/data/raw_doc_cache \
      /app/legacy/bid-generator/data/extracted_images \
      /app/legacy/bid-generator/data/projects \
      /app/legacy/bid-generator/data/kb_sync_status \
      /app/legacy/bid-generator/data/knowledge_base \
      /app/legacy/bid-generator/data/diagram_artifacts \
      /app/legacy/bid-generator/data/templates \
      /app/legacy/bid-generator/data/tender_documents

EXPOSE 5220

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
  CMD curl -fsS http://127.0.0.1:5220/api/v1/core/health || exit 1

CMD ["python", "-m", "uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "5220"]
